__pycache__/
*.py[cod]
*$py.class
*.so

# Job-scheduler stdout/stderr
*.out
*.err
*.log
*.logs

# PJM / nohup leftovers
nohup.out

# Runtime artefacts (stats, embeds, PID logs) — regenerated by the pipeline.
# Use rooted paths so we don't accidentally ignore source dirs named `embeds`/`data`.
/results/
/data/
pid/**/records/
pid/*/records/

# Model weight / tensor dumps
*.pt
*.pth
*.bin
*.safetensors

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
